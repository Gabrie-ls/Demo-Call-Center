# ============================================================
# CALLCENTER PLATFORM - VARIABLES DE ENTORNO
# Copia este archivo como .env y configura los valores
# ============================================================

# SERVIDOR
PORT=3000
NODE_ENV=development

# BASE DE DATOS PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=callcenter_db
DB_USER=postgres
DB_PASSWORD=123456

# JWT
JWT_SECRET=callcenter_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=8h

# BCRYPT
BCRYPT_ROUNDS=10

# CORS (dominio del frontend)
CORS_ORIGIN=http://localhost:8080

# UPLOADS
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
